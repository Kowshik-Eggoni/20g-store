# ============================================================
# 20g by NutriNomNom — Environment Variables
# Copy this file to .env and fill in your Shopify credentials
# ============================================================

# SESSION
SESSION_SECRET=your-random-32-char-secret-here

# Shopify Store Domain (e.g. your-store.myshopify.com)
PUBLIC_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront API Token (public, for frontend)
PUBLIC_STOREFRONT_API_TOKEN=your_public_storefront_api_token

# Shopify Storefront API Token (private, for server)
PRIVATE_STOREFRONT_API_TOKEN=your_private_storefront_api_token

# Shopify Storefront ID
PUBLIC_STOREFRONT_ID=your_storefront_id
